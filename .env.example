# ─────────────────────────────────────────────
#  Mugshot Studios — Environment Variables
#  Copy this file to .env and fill in values.
#  .env is git-ignored. .env.example is committed.
# ─────────────────────────────────────────────

# ── Email (Resend) ──────────────────────────
# Required to send contact-form submissions by email.
# Get a free key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Recipient address for inbound contact form emails
CONTACT_TO=admin@mugshotstudios.com

# Verified sender address in Resend.
# Until mugshotstudios.com is verified use: onboarding@resend.dev
CONTACT_FROM=Mugshot Studios <onboarding@resend.dev>

# ── Server ──────────────────────────────────
# Port for the Express dev server (default 5000)
PORT=5000

# ── Node Environment ────────────────────────
NODE_ENV=production
